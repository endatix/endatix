{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resource_prefix": {
      "value": "try-"
    },
    "environment": {
      "value": "sandbox"
    },
    "hubDeploymentMode": {
      "value": "static-site"
    },
    "branch": {
      "value": "main"
    },
    "hubRepositoryUrl": {
      "value": ""
    },
    "apiRepositoryUrl": {
      "value": ""
    },
    "apiDeploymentBranch": {
      "value": ""
    },
    "postgres_admin_username": {
      "value": "endatixadmin"
    },
    "postgres_admin_password": {
      "value": "CHANGE_ME_STRONG_PASSWORD"
    },
    "initialUserEmail": {
      "value": "admin@endatix.com"
    },
    "initialUserPassword": {
      "value": "CHANGE_ME_INITIAL_ADMIN_PASSWORD"
    },
    "endatixJwtSigningKey": {
      "value": "CHANGE_ME_ENDATIX_JWT_SIGNING_KEY"
    },
    "submissionsAccessTokenSigningKey": {
      "value": "CHANGE_ME_SUBMISSIONS_SIGNING_KEY"
    },
    "hubSessionSecret": {
      "value": "CHANGE_ME_HUB_SESSION_SECRET"
    },
    "hubAuthSecret": {
      "value": "CHANGE_ME_HUB_AUTH_SECRET"
    },
    "nextServerActionsEncryptionKey": {
      "value": "CHANGE_ME_NEXT_SERVER_ACTIONS_ENCRYPTION_KEY"
    },
