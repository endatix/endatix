        "ASPNETCORE_ENVIRONMENT": "Production"
      }
    },
    "apiConnectionStrings": {
      "value": {}
    },
    "enablePostgresqlHA": {
      "value": false
    },
    "storageIsPrivate": {
      "value": false
    },
    "enableFailureAnomalyAlerts": {
      "value": false
    }
  }
