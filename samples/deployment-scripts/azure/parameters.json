{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resource_prefix": {
      "value": "try-"
    },
    "environment": {
      "value": "sandbox"
    },
    "hubDeploymentMode": {
      "value": "static-site"
    },
    "branch": {
      "value": "main"
    },
    "hubRepositoryUrl": {
      "value": ""
    },
    "apiRepositoryUrl": {
      "value": ""
    },
    "apiDeploymentBranch": {
      "value": ""
    },
    "postgres_admin_username": {
      "value": "endatixadmin"
    },
    "postgres_admin_password": {
      "value": "CHANGE_ME_STRONG_PASSWORD"
    },
    "hubEnvironmentVariables": {
      "value": {
        "NEXT_PUBLIC_API_URL": "https://try-endatix-api.azurewebsites.net/api",
        "NEXT_PUBLIC_ENVIRONMENT": "production"
      }
    },
    "hubAppSettings": {
      "value": {}
    },
    "apiAppSettings": {
      "value": {
        "ASPNETCORE_ENVIRONMENT": "Production"
      }
    },
    "apiConnectionStrings": {
      "value": {}
    },
    "enablePostgresqlHA": {
      "value": false
    },
    "storageIsPrivate": {
      "value": false
    },
    "enableFailureAnomalyAlerts": {
      "value": false
    }
  }
}