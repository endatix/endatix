<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <!-- Assembly filters: test projects, EF migrations, integration hosts, provider adapters (integration-tested) -->
          <Exclude>[*.Tests]*,[*]*.Migrations.*,[Endatix.IntegrationTests]*,[Endatix.IntegrationTests.Shared]*,[Endatix.WebHost.IntegrationHost]*,[Endatix.Persistence.SqlServer]*,[Endatix.Persistence.PostgreSql]*,[Endatix.Hosting]*,[Endatix.WebHost]*,[Endatix.Api.Host]*</Exclude>
          <ExcludeByAttribute>Obsolete,GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
          <!-- File filters: tests, build output (source generators), EF migrations, embedded SQL script helpers -->
          <ExcludeByFile>**/tests/**/*.cs,**/obj/**/*.cs,**/Migrations/**/*.cs,**/Scripts/**/*.cs</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
